# ─── Shopify (obligatoire) ───────────────────────────────────────────────────
SHOPIFY_API_KEY=votre_client_id_partner_dashboard
SHOPIFY_API_SECRET=votre_client_secret_partner_dashboard
SCOPES=read_products,read_content,read_online_store_pages,read_legal_policies,read_markets,read_themes
# URL publique — SANS slash final
SHOPIFY_APP_URL=https://votre-app.up.railway.app

# ─── Base de données ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...

# ─── Support & App Store ─────────────────────────────────────────────────────
# Affiché sur /privacy et à renseigner dans le Partner Dashboard
SUPPORT_EMAIL=support@votre-domaine.fr

# ─── Cron audit planifié ────────────────────────────────────────────────────
CRON_SECRET=une-chaine-aleatoire-longue

# ─── Facturation Shopify ────────────────────────────────────────────────────
# manual (défaut) = Billing API in-app — fonctionne en revue App Store
# app_pricing = page hébergée Shopify — uniquement après publication live
SHOPIFY_BILLING_MODE=manual
# Dev / boutiques de test : true
# Production boutiques live : false (boutiques Partner dev → test auto même si false)
SHOPIFY_BILLING_TEST=false

# ─── Shopify App Pricing (Partner API) ─────────────────────────────────────
# Requis pour confirmer l'abonnement après paiement (App Pricing Partner Dashboard).
# Partner Dashboard → Settings → Partner API client (Manage apps)
# ID app Partner — le numéro seul suffit (ex. 394627055617)
SHOPIFY_PARTNER_ORG_ID=
SHOPIFY_PARTNER_ACCESS_TOKEN=
SHOPIFY_APP_GID=
# Handle slug (shopify.app.toml) — fallback si SHOPIFY_APP_GID absent
# Si 404 : l’ID numérique Partner (394627055617) est utilisé automatiquement via SHOPIFY_APP_GID
SHOPIFY_APP_HANDLE=jurishop

# ─── Alertes email (optionnel — Resend) ─────────────────────────────────────
RESEND_API_KEY=
ALERT_EMAIL_FROM=JuriShop <alerts@votre-domaine.com>
